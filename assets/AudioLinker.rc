#include "resource.h"
#include <winver.h>

IDI_APPICON ICON "AudioLinker.ico"
IDR_UI_HTML RCDATA "ui.html"
IDR_OPTIONS_HTML RCDATA "options.html"

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
 FILEFLAGS 0x0L
 FILEOS VOS_NT_WINDOWS32
 FILETYPE VFT_APP
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        // 040C = French (France), 04B0 = Unicode.
        BLOCK "040C04B0"
        BEGIN
            VALUE "CompanyName", "Valentin"
            VALUE "FileDescription", "AudioLinker - Groupe d'enceintes multi-sorties"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "AudioLinker"
            VALUE "OriginalFilename", "AudioLinker.exe"
            VALUE "ProductName", "AudioLinker"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x40C, 1200
    END
END
